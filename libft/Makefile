# Target library name
NAME = libft.a

# Compiler and required flags (including -g3 for debugging)
CC = gcc
CFLAGS = -Wall -Werror -Wextra -g3

# Archive command to create the static library
AR = ar rcs

# List of mandatory function names (without extensions)
SRC = ft_isalpha \
  ft_isdigit \
  ft_isalnum \
  ft_isascii \
  ft_isprint \
  ft_strlen \
  ft_memset \
  ft_bzero \
  ft_memcpy \
  ft_memmove \
  ft_strlcpy \
  ft_strlcat \
  ft_toupper \
  ft_tolower \
  ft_strchr \
  ft_strrchr \
  ft_strncmp \
  ft_memchr \
  ft_memcmp \
  ft_strnstr \
  ft_atoi \
  ft_calloc \
  ft_strdup \
  ft_substr \
  ft_strjoin \
  ft_strtrim \
  ft_split \
  ft_itoa \
  ft_strmapi \
  ft_striteri \
  ft_putchar_fd \
  ft_putstr_fd \
  ft_putendl_fd \
  ft_putnbr_fd

# List of bonus function names (without extensions)
BONUS_SRC = ft_lstnew \
  ft_lstadd_front \
  ft_lstsize \
  ft_lstlast \
  ft_lstadd_back \
  ft_lstdelone \
  ft_lstclear \
  ft_lstiter \
  ft_lstmap  

# Automatically append .c and .o extensions to the lists above
SRCS = $(addsuffix .c, $(SRC))
OBJS = $(addsuffix .o, $(SRC))
BONUS_SRCS = $(addsuffix .c, $(BONUS_SRC))
BONUS_OBJS = $(addsuffix .o, $(BONUS_SRC))

# Default rule: builds the mandatory library
all: $(NAME)

# Pattern rule: tells Make how to compile a .c file into a .o file
# $< is the first prerequisite (the .c file), $@ is the target (the .o file)
%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

# Rule to build the static library
# $@ is the target (libft.a), $^ is all prerequisites (all .o files)
$(NAME): $(OBJS)
	$(AR) $@ $^

# Rule to build the library including bonus object files
bonus: $(OBJS) $(BONUS_OBJS)
	$(AR) $(NAME) $^

# Cleans up all object files generated by the Makefile
clean:
	rm -f $(OBJS) $(BONUS_OBJS)

# Cleans up object files AND the compiled library
fclean: clean
	rm -f $(NAME)

# Fully recompiles everything from scratch
re: fclean all

# Declares these targets as "phony" (not actual files), preventing conflicts
# if a file named "clean" or "all" exists in the directory.
.PHONY: all clean fclean re bonus